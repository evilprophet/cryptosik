### ---------------------------------------------------------------------------
### App Runtime
### ---------------------------------------------------------------------------

# Application name displayed in UI.
APP_NAME=Cryptosik

# Application mode:
# - dev: fixed OTP code is used for login flow
# - prod: random OTP code is generated and sent by email
APP_MODE=dev

# Laravel runtime environment.
APP_ENV=local
APP_DEBUG=true

# Public base URL used by Laravel URL generation.
APP_URL=http://localhost

# Application timezone used for dates and times.
APP_TIMEZONE=Europe/Warsaw

# Trusted reverse proxies used for X-Forwarded-* headers.
# Use REMOTE_ADDR for a single local proxy hop, or comma-separated IP/CIDR list.
# Example: TRUSTED_PROXIES=REMOTE_ADDR
TRUSTED_PROXIES=

# Default UI language (en, pl, de, es).
APP_LOCALE=en

# Fallback language when translation key is missing.
APP_FALLBACK_LOCALE=en

# Application encryption key generated with `php artisan key:generate`.
APP_KEY=

### ---------------------------------------------------------------------------
### Database
### ---------------------------------------------------------------------------

# Choose one variant by setting DB_CONNECTION and keeping matching variables.
# Supported variants: mysql, sqlite

# --- MySQL variant ---
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=cryptosik
# DB_USERNAME=cryptosik
# DB_PASSWORD=cryptosik

# --- SQLite variant ---
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

### ---------------------------------------------------------------------------
### Cryptosik Security
### ---------------------------------------------------------------------------

# Secret pepper used in deterministic vault locator derivation.
CRYPTOSIK_LOOKUP_PEPPER=replace_with_long_random_secret

# Salt used in deterministic vault locator derivation.
CRYPTOSIK_LOOKUP_SALT=replace_with_long_random_salt

# OTP code used only when APP_MODE=dev.
CRYPTOSIK_DEV_OTP_CODE=111111

# Weekly unread notification cron (default: Saturday 09:00).
# Cron format: minute hour day-of-month month day-of-week
CRYPTOSIK_NOTIFICATIONS_WEEKLY_UNREAD_CRON="0 9 * * 6"

# Audit log retention in days.
# Allowed values: never, 30, 60, 90, 120
CRYPTOSIK_AUDIT_LOG_RETENTION_DAYS=never

# Audit log cleanup cron (default: every day at 03:15).
# Cron format: minute hour day-of-month month day-of-week
CRYPTOSIK_AUDIT_LOG_PRUNE_CRON="15 3 * * *"

# Max message content length in characters.
CRYPTOSIK_ENTRY_CONTENT_CHARS_LIMIT=2000000

# Admin panel URL path prefix (without leading slash).
CRYPTOSIK_ADMIN_PATH=admin

### ---------------------------------------------------------------------------
### Mail (SMTP)
### ---------------------------------------------------------------------------

# Mail transport. For production OTP delivery use smtp.
MAIL_MAILER=smtp

# SMTP host and port.
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls

# SMTP credentials.
# For Gmail use full account email and an App Password.
MAIL_USERNAME=your_smtp_user
MAIL_PASSWORD=your_smtp_password

# Sender address and display name.
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"
